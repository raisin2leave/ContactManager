### Variables
@Host = http://localhost:5022
@ContactId = 3d54091d-abc8-49ec-9590-93ad3ed5458f
@NoteId = 00000000-0000-0000-0000-000000000000

# NEW: Security Variables
@AdminEmail = admin@crm.pl
@AdminPassword = Admin@123!

@UserId = F5BADE14-6CC8-42A2-9A44-9842DA2D9280
@Role = Salesperson

# AUTHENTICATION 

### 0. Login - Get the JWT Token
# @name login
POST {{Host}}/api/auth/login
Content-Type: application/json

{
  "email": "{{AdminEmail}}",
  "password": "{{AdminPassword}}"
}

### Capture the token from the response
@Token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..udb5YEo8AweC1UN_20ru7BNBSRSEP3gog4YN-kQtbt8
### 1. GET all people
GET {{Host}}/api/contacts?page=1&size=10
Accept: application/json
Authorization: Bearer {{Token}}

### 2. GET specific person
GET {{Host}}/api/contacts/{{ContactId}}
Accept: application/json
Authorization: Bearer {{Token}}

### 3. POST - Create a valid person
POST {{Host}}/api/contacts
Content-Type: application/json
Authorization: Bearer {{Token}}

{
  "firstName": "Jan",
  "lastName": "Kowalski",
  "email": "jan.kowalski@wsei.edu.pl",
  "phone": "+48 500 600 700",
  "gender": 0,
  "birthDate": "1995-05-15T00:00:00Z"
}

### 4. PUT - Update existing person
PUT {{Host}}/api/contacts/{{ContactId}}
Content-Type: application/json
Authorization: Bearer {{Token}}

{
  "firstName": "Adam",
  "lastName": "Nowak-Updated",
  "email": "adam.updated@example.com",
  "status": 2
}


### 5. POST - Add a note to a person 
POST {{Host}}/api/contacts/{{ContactId}}/notes
Content-Type: application/json
Authorization: Bearer {{Token}}

{
  "content": "This is a new test note created in Lab 7"
}

### 6. GET - Get all notes for a person 
# Use this to find the NoteId for the delete task below!
GET {{Host}}/api/contacts/{{ContactId}}/notes
Accept: application/json
Authorization: Bearer {{Token}}

### 7. DELETE - Remove a note
# Replace NoteId at the top with a real ID from request #6
DELETE {{Host}}/api/contacts/{{ContactId}}/notes/{{NoteId}}
Authorization: Bearer {{Token}}

### 8. POST - Test Global Exception Handler 
# Send a note to a fake ID to see the ProblemDetails response
POST {{Host}}/api/contacts/00000000-0000-0000-0000-000000000000/notes
Content-Type: application/json
Authorization: Bearer {{Token}}

{
  "content": "This should trigger ContactNotFoundException"
}

### 9. GET - Verify Identity (Who am I?)
GET {{Host}}/api/auth/me
Authorization: Bearer {{Token}}

### 10. ADMIN - Block user
POST {{Host}}/api/admin/users/{{UserId}}/block
Authorization: Bearer {{Token}}

### 11. ADMIN - Unblock user
POST {{Host}}/api/admin/users/{{UserId}}/unblock
Authorization: Bearer {{Token}}

### 12. ADMIN - Deactivate user
POST {{Host}}/api/admin/users/{{UserId}}/deactivate
Authorization: Bearer {{Token}}

### 13. ADMIN - Activate user
POST {{Host}}/api/admin/users/{{UserId}}/activate
Authorization: Bearer {{Token}}

### 14. ADMIN - Assign role
POST {{Host}}/api/admin/users/{{UserId}}/roles/{{Role}}
Authorization: Bearer {{Token}}

### 15. ADMIN - Remove role
DELETE {{Host}}/api/admin/users/{{UserId}}/roles/{{Role}}
Authorization: Bearer {{Token}}